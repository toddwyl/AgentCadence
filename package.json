{
  "name": "agentcadence",
  "version": "1.0.0",
  "description": "AgentCadence — web-based universal CLI orchestration workbench (TypeScript; evolved from AgentCrew)",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-spawn-helper.mjs",
    "dev": "DEV_PORT=${PORT:-3712}; node scripts/ensure-dev-port-free.mjs \"$DEV_PORT\" && concurrently --kill-others-on-fail \"PORT=$DEV_PORT npm run dev:server\" \"wait-on tcp:$DEV_PORT && VITE_BACKEND_PORT=$DEV_PORT npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "node scripts/agentcadence-integration.mjs",
    "test:e2e": "node scripts/agentcadence-e2e-browser.mjs",
    "test:smoke": "node scripts/agentcadence-smoke.mjs",
    "test:e2e-run": "node scripts/agentcadence-e2e-full-run.mjs",
    "test:e2e-cursor": "node scripts/agentcadence-e2e-cursor-agent.mjs",
    "test:harness": "bash scripts/harness.sh",
    "capture:demo-gif": "node scripts/capture-readme-demo-gif.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "ghostty-web": "^0.4.0",
    "highlight.js": "^11.11.1",
    "node-pty": "^1.1.0",
    "node-cron": "^4.2.1",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^10.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.1",
    "ansi-to-html": "^0.7.2",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "lucide-react": "^0.441.0",
    "playwright": "^1.58.2",
    "postcss": "^8.4.45",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rehype-highlight": "^7.0.2",
    "tailwindcss": "^3.4.10",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.3",
    "wait-on": "^8.0.1",
    "vitest": "^4.1.4",
    "zustand": "^4.5.5"
  }
}
